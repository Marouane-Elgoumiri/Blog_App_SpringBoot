# ============================================
# CogniPost Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
# ============================================

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# DEV Profile: Uses local PostgreSQL at localhost:5432/cognipost
# POSTGRES Profile: Uses environment variables for production

# Database password for dev profile (if your PostgreSQL requires authentication)
DB_PASSWORD=

# Production database URL (used by 'postgres' profile)
DB_URL=jdbc:postgresql://localhost:5432/cognipost
DB_USERNAME=admin
# DB_PASSWORD=your_secure_database_password  [REQUIRED for production]

# --------------------------------------------
# JWT Authentication [REQUIRED]
# Must be at least 256 bits (32 characters) for HS256
# --------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-chars-long

# --------------------------------------------
# CORS Configuration
# Comma-separated list of allowed origins
# --------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --------------------------------------------
# Mail Server [OPTIONAL]
# Notifications are disabled if not configured
# For Gmail: use an App Password, not your account password
# --------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --------------------------------------------
# Server
# --------------------------------------------
PORT=8080
