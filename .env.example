# ============================================
# CogniPost Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
# ============================================

# --------------------------------------------
# Database (Required for prod profile)
# --------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/blog_app
DB_USERNAME=bloguser
DB_PASSWORD=your_secure_database_password

# --------------------------------------------
# JWT Authentication [REQUIRED]
# Must be at least 256 bits (32 characters) for HS256
# --------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-chars-long

# --------------------------------------------
# CORS Configuration
# Comma-separated list of allowed origins
# --------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --------------------------------------------
# Mail Server [OPTIONAL]
# Notifications are disabled if not configured
# For Gmail: use an App Password, not your account password
# --------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --------------------------------------------
# Server
# --------------------------------------------
PORT=8080
